// ALE Platform — Prisma Schema
// Run: npx prisma db push   (to apply to Supabase)
// Run: npx prisma studio    (to browse data)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  learner
  mentor
  admin
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
}

enum CourseStatus {
  draft
  published
  archived
}

enum LessonType {
  video
  text
  quiz
  project
  simulation
}

enum EnrolmentStatus {
  active
  completed
  paused
}

enum QuestionType {
  mcq
  multi_select
  true_false
  short_answer
}

enum QuestionDifficulty {
  easy
  medium
  hard
}

enum SkillCategory {
  technical
  professional
  leadership
  industry
}

enum BadgeCriteriaType {
  course_complete
  streak
  score
  xp_threshold
  manual
}

enum ReactionType {
  like
  helpful
  bookmark
}

// ─── IDENTITY & PROFILE ──────────────────────────────────────────────────────

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  name         String    @db.VarChar(255)
  avatarUrl    String?   @map("avatar_url")
  country      String?   @db.VarChar(100)
  primaryLang  String    @default("en") @map("primary_language") @db.VarChar(50)
  timezone     String?   @db.VarChar(100)
  role         UserRole  @default(learner)
  isVerified   Boolean   @default(false) @map("is_verified")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  profile            LearnerProfile?
  enrolments         Enrolment[]
  lessonCompletions  LessonCompletion[]
  assessmentAttempts AssessmentAttempt[]
  userSkills         UserSkill[]
  userBadges         UserBadge[]
  posts              Post[]
  postReactions      PostReaction[]
  postReplies        PostReply[]
  activityEvents     ActivityEvent[]
  tutorMessages      TutorMessage[]
  refreshTokens      RefreshToken[]
  createdCourses     Course[]            @relation("CourseCreator")

  @@map("users")
}

model LearnerProfile {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  careerGoal          String?   @map("career_goal") @db.VarChar(255)
  currentRole         String?   @map("current_role") @db.VarChar(255)
  experienceYears     Int?      @map("experience_years")
  industry            String?   @db.VarChar(255)
  educationLevel      String?   @map("education_level") @db.VarChar(100)
  learningStyles      String[]  @map("learning_styles")
  dailyCommitmentMins Int?      @map("daily_commitment_mins")
  motivationScore     Decimal?  @map("motivation_score") @db.Decimal(3, 2)
  activePathId        String?   @map("active_path_id") @db.Uuid
  xpTotal             Int       @default(0) @map("xp_total")
  level               Int       @default(1)
  streakDays          Int       @default(0) @map("streak_days")
  streakLastDate      DateTime? @map("streak_last_date") @db.Date
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activePath LearningPath? @relation(fields: [activePathId], references: [id])

  @@map("learner_profiles")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── COURSE CONTENT ──────────────────────────────────────────────────────────

model Course {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                  String       @unique @db.VarChar(100)
  title                 String       @db.VarChar(255)
  description           String?      @db.Text
  thumbnailUrl          String?      @map("thumbnail_url")
  level                 CourseLevel
  estimatedHours        Decimal?     @map("estimated_hours") @db.Decimal(4, 1)
  status                CourseStatus @default(draft)
  tags                  String[]
  prerequisiteCourseIds String[]     @map("prerequisite_course_ids") @db.Uuid
  displayOrder          Int          @default(0) @map("display_order")
  createdBy             String?      @map("created_by") @db.Uuid
  publishedAt           DateTime?    @map("published_at") @db.Timestamptz()
  maintenanceMessage    String?      @map("maintenance_message") @db.Text
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  creator            User?               @relation("CourseCreator", fields: [createdBy], references: [id])
  modules            Module[]
  enrolments         Enrolment[]
  assessmentAttempts AssessmentAttempt[]
  questions          Question[]
  posts              Post[]
  pathItems          LearningPathItem[]

  @@map("courses")
}

model Module {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String  @map("course_id") @db.Uuid
  title         String  @db.VarChar(255)
  displayOrder  Int     @map("display_order")
  estimatedMins Int?    @map("estimated_mins")
  isFreePreview Boolean @default(false) @map("is_free_preview")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId          String     @map("module_id") @db.Uuid
  title             String     @db.VarChar(255)
  type              LessonType
  displayOrder      Int        @map("display_order")
  contentBody       String?    @map("content_body") @db.Text
  videoAssetId      String?    @map("video_asset_id") @db.VarChar(255)
  videoDurationSecs Int?       @map("video_duration_secs")
  estimatedMins     Int?       @map("estimated_mins")
  xpReward          Int        @default(10) @map("xp_reward")

  module      Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]
  questions   Question[]

  @@map("lessons")
}

// ─── ENROLMENT & PROGRESS ────────────────────────────────────────────────────

model Enrolment {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  courseId    String          @map("course_id") @db.Uuid
  status      EnrolmentStatus @default(active)
  progressPct Decimal         @default(0) @map("progress_pct") @db.Decimal(5, 2)
  enrolledAt  DateTime        @default(now()) @map("enrolled_at") @db.Timestamptz()
  completedAt DateTime?       @map("completed_at") @db.Timestamptz()

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrolments")
}

model LessonCompletion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  lessonId      String   @map("lesson_id") @db.Uuid
  completedAt   DateTime @default(now()) @map("completed_at") @db.Timestamptz()
  timeSpentSecs Int?     @map("time_spent_secs")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_completions")
}

// ─── ASSESSMENTS ─────────────────────────────────────────────────────────────

model Question {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId      String?            @map("lesson_id") @db.Uuid
  courseId      String?            @map("course_id") @db.Uuid
  text          String             @db.Text
  type          QuestionType
  options       Json?
  correctAnswer Json               @map("correct_answer")
  explanation   String?            @db.Text
  difficulty    QuestionDifficulty @default(medium)
  skillTags     String[]           @map("skill_tags")
  xpReward      Int                @default(5) @map("xp_reward")

  lesson Lesson? @relation(fields: [lessonId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])

  @@map("questions")
}

model AssessmentAttempt {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  courseId      String?  @map("course_id") @db.Uuid
  lessonId      String?  @map("lesson_id") @db.Uuid
  scorePct      Decimal  @map("score_pct") @db.Decimal(5, 2)
  answers       Json
  passed        Boolean
  timeTakenSecs Int?     @map("time_taken_secs")
  attemptedAt   DateTime @default(now()) @map("attempted_at") @db.Timestamptz()

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])

  @@map("assessment_attempts")
}

// ─── SKILLS & CREDENTIALS ────────────────────────────────────────────────────

model SkillDefinition {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @unique @db.VarChar(255)
  category    SkillCategory
  description String?       @db.Text
  icon        String?       @db.VarChar(50)

  userSkills UserSkill[]

  @@map("skill_definitions")
}

model UserSkill {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  skillId        String    @map("skill_id") @db.Uuid
  proficiencyPct Decimal   @default(0) @map("proficiency_pct") @db.Decimal(5, 2)
  evidenceCount  Int       @default(0) @map("evidence_count")
  lastAssessedAt DateTime? @map("last_assessed_at") @db.Timestamptz()

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill SkillDefinition @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
  @@map("user_skills")
}

model Badge {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String            @unique @db.VarChar(255)
  description   String?           @db.Text
  icon          String?           @db.VarChar(100)
  criteriaType  BadgeCriteriaType @map("criteria_type")
  criteriaValue Json              @map("criteria_value")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  badgeId   String   @map("badge_id") @db.Uuid
  awardedAt DateTime @default(now()) @map("awarded_at") @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ─── LEARNING PATH ───────────────────────────────────────────────────────────

model LearningPath {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz()
  isActive    Boolean  @default(true) @map("is_active")

  items    LearningPathItem[]
  profiles LearnerProfile[]

  @@map("learning_paths")
}

model LearningPathItem {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pathId         String  @map("path_id") @db.Uuid
  courseId       String  @map("course_id") @db.Uuid
  displayOrder   Int     @map("display_order")
  rationale      String? @db.Text
  estimatedWeeks Int?    @map("estimated_weeks")

  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id])

  @@unique([pathId, courseId])
  @@map("learning_path_items")
}

// ─── COMMUNITY ───────────────────────────────────────────────────────────────

model Post {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(500)
  body      String   @db.Text
  courseId  String?  @map("course_id") @db.Uuid
  isPinned  Boolean  @default(false) @map("is_pinned")
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course?        @relation(fields: [courseId], references: [id])
  reactions PostReaction[]
  replies   PostReply[]

  @@map("posts")
}

model PostReply {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_replies")
}

model PostReaction {
  id     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId String       @map("post_id") @db.Uuid
  userId String       @map("user_id") @db.Uuid
  type   ReactionType

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@map("post_reactions")
}

// ─── AI TUTOR ────────────────────────────────────────────────────────────────

model TutorMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @db.VarChar(10) // "user" | "assistant"
  content   String   @db.Text
  courseId  String?  @map("course_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tutor_messages")
}

// ─── PATH GENERATION JOBS ────────────────────────────────────────────────────

model PathGenerationJob {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  status      String    @default("pending") @db.VarChar(20) // pending | complete | failed
  error       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()

  @@map("path_generation_jobs")
}

// ─── ANALYTICS ───────────────────────────────────────────────────────────────

model ActivityEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  eventType  String   @map("event_type") @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_events")
}
